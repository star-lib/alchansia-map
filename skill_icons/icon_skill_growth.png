<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="viewport-fit=cover, width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" href="./favicon.ico" />
    <link rel="apple-touch-icon" href="./icon-192.png" />
    <title>Alcanthia</title>
    <style>
      @font-face {
        font-family: 'Zen Serif';
        src: url('assets/fonts/ZEN-SERIF-Regular.otf') format('opentype'),
             url('assets/fonts/ZEN-SERIF-Regular.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: block;
      }
      * { margin: 0; padding: 0; }
      html, body {
        margin: 0;
        overflow: hidden;
        background: #1a1a2e;
        overscroll-behavior: none;
        touch-action: none;
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
        -webkit-tap-highlight-color: transparent;
        position: fixed;
        width: 100%;
        height: 100%;
      }
      :root {
        --safe-top: env(safe-area-inset-top, 0px);
        --safe-right: env(safe-area-inset-right, 0px);
        --safe-bottom: env(safe-area-inset-bottom, 0px);
        --safe-left: env(safe-area-inset-left, 0px);
      }
    </style>
    <script type="module" crossorigin src="./assets/index-DefdI0qg.js"></script>
  <link rel="manifest" href="./manifest.webmanifest"></head>
  <body>
    <script>
      function clearAllCaches() {
        return caches.keys().then(function(keys) {
          return Promise.all(keys.map(function(k) { return caches.delete(k); }));
        });
      }

      // 모듈 로드 실패 시 SW unregister + 캐시 삭제 후 새로고침
      window.addEventListener('error', function(e) {
        if (!navigator.serviceWorker) return;
        var t = e.target;
        if (!(t instanceof HTMLScriptElement) || t.type !== 'module') return;
        if (sessionStorage.getItem('sw-recovery')) return;
        sessionStorage.setItem('sw-recovery', '1');
        navigator.serviceWorker.getRegistrations().then(function(rs) {
          return Promise.all(rs.map(function(r) { return r.unregister(); }));
        }).then(clearAllCaches).then(function() {
          location.reload();
        });
      }, true);
    </script>
    <div id="loading-screen" style="position:fixed;inset:0;background:#1a1a2e;color:#e0d8c8;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;font-family:'Zen Serif',serif;text-align:center;padding:24px;">
      <p style="font-size:48px;margin:0 0 16px">🌱</p>
      <p style="font-size:16px;margin:0 0 32px">업데이트 중...</p>
      <a href="https://discord.gg/BcWCfCztsy" target="_blank" style="font-family:inherit;font-size:14px;padding:10px 24px;background:#5865F2;color:#fff;border:none;border-radius:8px;text-decoration:none;display:inline-flex;align-items:center;gap:4px;"><img src="./assets/ui/logo_discord.png" style="width:16px;height:16px;">디스코드</a>
      <button onclick="clearAllCaches().then(function(){location.reload()})" style="font-family:inherit;font-size:12px;margin-top:16px;background:none;border:none;color:#e0d8c8;text-decoration:underline;cursor:pointer;opacity:0.6;">캐시 삭제</button>
    </div>
  </body>
</html>
